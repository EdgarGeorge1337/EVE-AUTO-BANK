// EVE Auto Bank - Prisma Schema
// PLEX-secured lending system for EVE Online

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH / USER MODELS
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  character Character?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// EVE CHARACTER
// ============================================================

model Character {
  id              String   @id @default(cuid())
  userId          String   @unique
  characterId     Int      @unique
  characterName   String
  corporationId   Int?
  allianceId      Int?
  accessToken     String?
  refreshToken    String?
  tokenExpiry     DateTime?
  scopes          String?  // space-separated ESI scopes
  isAdmin         Boolean  @default(false)
  creditScore     Int      @default(500)
  trustTier       String   @default("BASIC") // BASIC | STANDARD | ADVANCED | PREMIUM
  totalLoans      Int      @default(0)
  totalRepaid     Int      @default(0)
  totalDefaulted  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans    Loan[]
  payments Payment[]
  auditLogs AuditLog[]
  trades   TradeOrder[]
  fundPositions    FundPosition[]
  fundTransactions FundTransaction[]
}

// ============================================================
// LOAN MODELS
// ============================================================

model Loan {
  id          String   @id @default(cuid())
  characterId String

  // Loan terms
  principalAmount   Float
  interestRate      Float    // e.g. 0.08 = 8%
  termDays          Int
  dueDate           DateTime
  finalPaymentDate  DateTime?

  // Status
  status            LoanStatus @default(PENDING)
  approvalReason    String?
  autoApprovalEligible Boolean @default(false)

  // Collateral
  collateralType        String   @default("PLEX") // PLEX | MIXED
  collateralPlexQty     Int      @default(0)
  collateralPlexValue   Float    // total collateral value at time of loan
  collateralContractId  String?  // ESI contract ID
  returnContractId      String?  // contract ID for returning collateral
  ltvRatio              Float    // loan-to-value ratio

  // Insurance
  hasInsurance      Boolean  @default(false)

  // Tracking
  amountRepaid          Float    @default(0)
  nextPaymentDue        DateTime?
  overdueAt             DateTime?
  defaultedAt           DateTime?
  collateralLiquidatedAt    DateTime?
  collateralLiquidatedValue Float?
  cancelledAt           DateTime?
  completedAt           DateTime?
  iskSentAt             DateTime?  // when admin marked ISK as sent to borrower

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character       Character       @relation(fields: [characterId], references: [id])
  payments        Payment[]
  insurance       LoanInsurance?
  auditLogs       AuditLog[]
  collateralItems CollateralItem[]

  @@index([characterId])
  @@index([status])
  @@index([dueDate])
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  OVERDUE
  DEFAULTED
  COMPLETED
  CANCELLED
}

model Payment {
  id          String   @id @default(cuid())
  loanId      String
  characterId String

  amount        Float
  type          PaymentType @default(REGULAR)

  // ESI verification
  esiTransactionId String?
  journalRefId     String?
  verified         Boolean @default(false)

  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  loan      Loan      @relation(fields: [loanId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@index([loanId])
  @@index([characterId])
  @@index([esiTransactionId])
}

enum PaymentType {
  REGULAR
  EARLY
  PARTIAL
  INSURANCE_CLAIM
  COLLATERAL_LIQUIDATION
}

model LoanInsurance {
  id     String @id @default(cuid())
  loanId String @unique

  coverageTier     String   @default("STANDARD") // BASIC | STANDARD | PREMIUM
  premiumAmount    Float
  premiumRate      Float    @default(0.02)
  coveragePercent  Float    // e.g. 0.80 = 80%

  // Claim lifecycle
  claimStatus       String    @default("NONE") // NONE | PENDING_REVIEW | APPROVED | DENIED
  claimRequestedAt  DateTime?
  claimedAt         DateTime?
  claimAmount       Float?
  claimDenialReason String?
  claimable         Boolean   @default(true) // legacy compat

  createdAt DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id])
}

model CollateralItem {
  id         String @id @default(cuid())
  loanId     String
  typeName   String
  typeId     Int
  qty        Int
  unitValue  Float  // Janice split price at time of loan
  totalValue Float

  loan Loan @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

model InsurancePool {
  id                String   @id @default(cuid())
  premiumsCollected Float    @default(0)
  claimsPaid        Float    @default(0)
  updatedAt         DateTime @updatedAt
}

// ============================================================
// TRADING DESK
// ============================================================

// Bank buys/sells items at Janice-derived quotes with a spread.
// Like loans, in-game transfers are executed manually by the admin;
// the order tracks the lifecycle and drives the admin action queue.
model TradeOrder {
  id          String @id @default(cuid())
  characterId String

  side     TradeSide // BUY = player buys from bank, SELL = player sells to bank
  typeName String
  typeId   Int
  qty      Int

  unitPrice   Float // quoted price per unit after spread
  totalValue  Float // unitPrice * qty
  marketPrice Float // Janice split price per unit at quote time
  spreadPct   Float

  status TradeStatus @default(OPEN)

  // Lifecycle timestamps
  expiresAt          DateTime  // player must transfer before this or the order expires
  transferReceivedAt DateTime? // bank received ISK (BUY) or item contract (SELL)
  fulfilledAt        DateTime? // bank delivered items (BUY) or ISK (SELL)
  cancelledAt        DateTime?
  contractId         String?   // in-game contract / transfer reference

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id])

  @@index([characterId])
  @@index([status])
  @@index([expiresAt])
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  RECEIVED
  COMPLETED
  CANCELLED
  EXPIRED
}

// ============================================================
// INDEX FUND
// ============================================================

// A bank-operated basket of items. Users subscribe with ISK and
// receive units at the current NAV per unit; redemptions pay out
// at NAV. The bank character holds the assets in-game; holdings
// here mirror what the admin actually bought/sold with fund cash.
model IndexFund {
  id               String  @id @default(cuid())
  name             String
  description      String
  status           String  @default("ACTIVE") // ACTIVE | CLOSED
  managementFeePct Float   @default(0.0)
  entryFeePct      Float   @default(0.01)
  unitsOutstanding Float   @default(0)
  cashBalance      Float   @default(0) // ISK held by the fund, not yet invested

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdings     FundHolding[]
  positions    FundPosition[]
  transactions FundTransaction[]
  navSnapshots FundNavSnapshot[]
}

model FundHolding {
  id       String @id @default(cuid())
  fundId   String
  typeName String
  typeId   Int
  qty      Float
  avgCost  Float // average ISK paid per unit

  updatedAt DateTime @updatedAt

  fund IndexFund @relation(fields: [fundId], references: [id])

  @@unique([fundId, typeId])
  @@index([fundId])
}

model FundPosition {
  id          String @id @default(cuid())
  fundId      String
  characterId String

  units       Float @default(0)
  iskInvested Float @default(0) // lifetime subscriptions (cost basis)
  iskRedeemed Float @default(0) // lifetime redemptions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fund      IndexFund @relation(fields: [fundId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([fundId, characterId])
  @@index([characterId])
}

model FundTransaction {
  id          String @id @default(cuid())
  fundId      String
  characterId String

  type       String // SUBSCRIBE | REDEEM
  iskAmount  Float  // SUBSCRIBE: deposit; REDEEM: payout (set at processing)
  units      Float? // SUBSCRIBE: issued at processing; REDEEM: units requested
  navPerUnit Float? // NAV/unit used at processing

  status TradeStatus @default(OPEN)

  expiresAt          DateTime
  transferReceivedAt DateTime?
  processedAt        DateTime?
  cancelledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fund      IndexFund @relation(fields: [fundId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@index([fundId])
  @@index([characterId])
  @@index([status])
}

model FundNavSnapshot {
  id     String @id @default(cuid())
  fundId String

  nav              Float // total fund value (holdings + cash)
  navPerUnit       Float
  holdingsValue    Float
  cashBalance      Float
  unitsOutstanding Float

  createdAt DateTime @default(now())

  fund IndexFund @relation(fields: [fundId], references: [id])

  @@index([fundId, createdAt])
}

// Per-region economy figures from CCP's Monthly Economic Report
// (mirrored at data.everef.net/ccp/mer/). One row per region per month.
// These are the "published monthly earnings reports" behind the
// Sector Reports view — regions act as market sectors.
model SectorReport {
  id     String @id @default(cuid())
  month  String // "2026-06"
  region String

  minedValue     Float
  producedValue  Float
  destroyedValue Float
  npcBounties    Float
  loyaltyPoints  Float
  tradeValue     Float

  createdAt DateTime @default(now())

  @@unique([month, region])
  @@index([month])
}

// Market price history for the insights watchlist, captured by the
// monitoring cycle. Powers 24h/7d change and buy/hold/sell signals.
model PriceSnapshot {
  id        String   @id @default(cuid())
  typeName  String
  typeId    Int
  buyMax    Float
  sellMin   Float
  splitPrice Float
  createdAt DateTime @default(now())

  @@index([typeId, createdAt])
}

// ============================================================
// AUDIT & MONITORING
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  loanId      String?
  characterId String?

  action      String
  description String
  metadata    String?  // JSON string

  createdAt DateTime @default(now())

  loan      Loan?      @relation(fields: [loanId], references: [id])
  character Character? @relation(fields: [characterId], references: [id])

  @@index([loanId])
  @@index([characterId])
  @@index([action])
  @@index([createdAt])
}

model PlexPriceCache {
  id        String   @id @default(cuid())
  price     Float
  region    String   @default("10000002") // The Forge / Jita
  source    String   @default("ESI")
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

model BankConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt

  @@index([key])
}

// Stores the bank character's ESI tokens from App 2 (admin API app)
// One row — the bank character. Updated on every refresh.
model BankToken {
  id           String   @id @default(cuid())
  characterId  Int      @unique
  characterName String
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  scopes       String   // space-separated, for reference
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
