# EVE Auto Bank Environment Variables

# Database
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# EVE ESI Configuration
ESI_CLIENT_ID="your-esi-client-id"
ESI_CLIENT_SECRET="your-esi-client-secret"
ESI_CALLBACK_URL="http://localhost:3000/api/auth/callback/eve"

# EVE Bank Character (Admin)
ADMIN_CHARACTER_ID="123456789"
ADMIN_CHARACTER_NAME="Your Bank Character"

# Discord Webhooks (Optional - for future use)
# DISCORD_WEBHOOK_ANNOUNCEMENTS="https://discord.com/api/webhooks/..."
# DISCORD_WEBHOOK_DEFAULTS="https://discord.com/api/webhooks/..."
# DISCORD_WEBHOOK_UPDATES="https://discord.com/api/webhooks/..."
# DISCORD_WEBHOOK_ADMIN="https://discord.com/api/webhooks/..."

# System Configuration
GRACE_PERIOD_DAYS="7"
MAX_LTV_RATIO="0.70"
BASE_INTEREST_RATE="0.08"
LOAN_TERM_DAYS="30"

# Logging
LOG_LEVEL="info"

# Janice Asset Appraisal API (https://janice.e-351.com)
JANICE_API_KEY="your-janice-api-key"
